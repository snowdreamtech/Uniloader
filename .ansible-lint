---
# .ansible-lint
# Production profile ensures code adheres to strict best practices
profile: production

# List of rules to set as warnings instead of failing the linting process
warn_list:
  - experimental

# List of rules to entirely skip during linting
skip_list:
  - no-handler
  - name[missing]
  - name[template]
  - fqcn-builtins          # Fully Qualified Collection Names are auto-fixed via AST tools
  - yaml                   # Prevent ansible-lint from altering established YAML formatting conventions
  - no-changed-when        # The loader framework is declarative and does not require explicit changed_when evaluations
  - risky-file-permissions
  - command-instead-of-shell
  - var-naming             # The project maintains its own custom variable naming conventions outside the lint scope
  - meta-no-info           # Role metadata (meta/main.yml) is not necessary for the current architectural pattern

# Custom rule directories to load
rulesdir:
  - .ansible-lint-rules

# Specific rules to force-enable (those that are otherwise not in the base profile)
enable_list:
  - fqcn
  - command-instead-of-module

# Mock modules that are external or unavailable during the static analysis phase
mock_modules:
  - community.docker.docker_container
  - containers.podman.podman_container

# Using enable_list is sufficient for default rules.
